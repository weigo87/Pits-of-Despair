IF
  True()
THEN
  RESPONSE #100
    CutSceneId(Player1)
    ClearActions("zbneph")
    SetGlobal("ZB_NEPH_MOVE_COPPER","GLOBAL",2)
    SetGlobal("ZB_NEPH_COPPERCORENT","GLOBAL",1)
    ApplySpell("zbneph",WIZARD_INVISIBILITY)
    SmallWait(25)
    ActionOverride("zbneph",DestroySelf())
    EndCutSceneMode()
END

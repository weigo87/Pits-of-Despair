  END
  READ_LONG   0x84 ambi_off
  PATCH_IF (~%ambi_off%~ >= ~%actor_off%~) BEGIN
    WRITE_LONG 0x84 ~%ambi_off%~ - ~%actor_num%~ * 0x110
  END
  READ_LONG   0x88 var_off
  PATCH_IF (~%var_off%~ >= ~%actor_off%~) BEGIN

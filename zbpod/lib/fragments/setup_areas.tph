///
// Overwrite Pits files
///
COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/area/zb8x~

// HUB
COPY_EXISTING ~OH8100.ARE~ ~override/ZB8100.ARE~
  WRITE_ASCII AREA_SCRIPT ~zbbhub~ #8

// Arena
COPY_EXISTING ~OH8200.ARE~ ~override/ZB8200.ARE~
  WRITE_ASCII AREA_SCRIPT ~zbbare1~ #8
COPY_EXISTING ~OH8300.ARE~ ~override/ZB8300.ARE~
  WRITE_ASCII AREA_SCRIPT ~zbbare1~ #8
COPY_EXISTING ~OH8400.ARE~ ~override/ZB8400.ARE~
  WRITE_ASCII AREA_SCRIPT ~zbbare1~ #8

// Update area files
APPEND ~MASTAREA.2da~ ~ZB8100     value      ~
UNLESS ~ZB8100~
APPEND ~MASTAREA.2da~ ~ZB8200     value      ~
UNLESS ~ZB8200~
APPEND ~MASTAREA.2da~ ~ZB8300     value      ~
UNLESS ~ZB8300~
APPEND ~MASTAREA.2da~ ~ZB8400     value      ~
UNLESS ~ZB8400~


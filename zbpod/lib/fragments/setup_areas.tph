// ZB2010
COPY ~%MOD_FOLDER%/creatures/zbtavern~ ~override~

COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/area/zb2010/zb2010.baf~

COPY ~%MOD_FOLDER%/area/zb2010/zb2010.are~ ~override~

APPEND ~MASTAREA.2da~ ~ZB2010     value      ~
UNLESS ~ZB2010~

// Add neph to trademeet inn after escape
EXTEND_BOTTOM ~AR2010.BCS~ ~%MOD_FOLDER%/area/ar2010/ar2010.baf~
  EVALUATE_BUFFER

// Add neph to COPPERCORENT 
EXTEND_BOTTOM ~AR0406.BCS~ ~%MOD_FOLDER%/area/ar0406/ar0406.baf~
  EVALUATE_BUFFER

// Create Animal training area
COPY_EXISTING ~OH8200.ARE~ ~override/ZB8201.ARE~
WRITE_ASCII AREA_SCRIPT ~zbbare1~ #8
READ_LONG   0x54 actor_off
READ_SHORT  0x58 actor_num
PATCH_IF (~%actor_num%~ > 0) BEGIN
  WRITE_SHORT 0x58 0
  READ_LONG   0x5c triggers_off

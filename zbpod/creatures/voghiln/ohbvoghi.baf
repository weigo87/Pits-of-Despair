IF
	Dead("ohbvoghi")  // Voghiln the Vast
THEN
	RESPONSE #100
		DestroySelf()
END

IF
	Global("OHB_START_BATTLE","GLOBAL",2)
	OR(3)
		AreaCheck("ZB8200")  // TBP2 - Arena 1
		AreaCheck("ZB8300")  // TBP2 - Arena 2
		AreaCheck("ZB8400")  // TBP2 - Arena 3
THEN
	RESPONSE #100
		NoAction()
END

IF
	Global("ohb_voghiln_hired","global",3)
	!AreaCheck("oh8100")  // TBP2 - Staging Area Map
THEN
	RESPONSE #100
		SetGlobal("ohb_voghiln_hired","global",4)
		EquipRanged()
END

IF
	Global("OHB_TALKED_VOGHI","LOCALS",0)
	Global("zb_voghiln_greeting","GLOBAL",1)  // TBP2 - Staging Area Map
THEN
	RESPONSE #100
		StartDialogueNoSet(Player1)
END

IF
	Global("OHB_TALKED_VOGHI","LOCALS",1)
	Global("OHB_DINNERBELL","ZB8100",0)  // TBP2 - Staging Area Map
	Global("OHB_VOGHI_WALK","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("OHB_VOGHI_WALK","LOCALS",1)
		MoveToPointNoInterrupt([2260.1645])
		Face(SW)
END

